{
  "name": "whatsapp-dot-notifier",
  "version": "1.0.0",
  "description": "A tiny always-on-top dot that blinks when a specific WhatsApp contact messages you.",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win portable"
  },
  "devDependencies": {
    "electron": "^42.3.3",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.yourname.whatsapp-dot-notifier",
    "productName": "WhatsApp Dot Notifier",
    "win": {
      "target": "portable",
      "icon": "assets/icon.ico"
    },
    "files": [
      "main.js",
      "preload-overlay.js",
      "preload-whatsapp.js",
      "overlay.html",
      "config.json",
      "assets/**"
    ]
  }
}
